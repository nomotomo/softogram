  "technical_instructions": {
    "dependencies": {
      "framer-motion": "Required for all animations",
      "lenis": "Required for smooth scrolling",
      "clsx": "For class merging",
      "tailwind-merge": "For class merging",
      "react-countup": "For stats section",
      "react-fast-marquee": "For testimonials/clients"
    },
    "fonts": {
      "google_fonts_url": "https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Plus+Jakarta+Sans:wght@600;700;800&display=swap"
    },
    "global_css": "Add 'scroll-smooth' to html. Use Lenis for body scroll hijacking.",
    "testing": "All interactive elements must have data-testid attributes."
  },
  "universal_guidelines": {
    "do_not": [
      "Use gradients for text unless it's a very specific highlight.",
      "Use default scrollbars.",
      "Center text in cards (Align Left usually looks better for readabilty).",
      "Use 'Inter' for headings."
    ],
    "must": [
      "Use 'Plus Jakarta Sans' for all headings.",
      "Add hover states to ALL interactive elements.",
      "Use 3x more padding than you think is necessary."
    ]
  }
