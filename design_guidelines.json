{
  "brand_identity": {
    "name": "Softogram",
    "tagline": "Your idea. Our code. Delivered.",
    "tone": "Premium, Technical, Trustworthy, Modern",
    "theme_mode": "dark",
    "primary_color": "#0A0F2C",
    "accent_color": "#3B82F6",
    "secondary_accent": "#7C3AED",
    "surface_color": "#111827",
    "text_primary": "#F8FAFC",
    "text_secondary": "#94A3B8"
  },
  "typography": {
    "headings": {
      "font_family": "Plus Jakarta Sans, sans-serif",
      "weights": ["600", "700", "800"],
      "letter_spacing": "-0.02em"
    },
    "body": {
      "font_family": "Inter, sans-serif",
      "weights": ["400", "500"],
      "letter_spacing": "0em"
    }
  },
  "layout_strategy": {
    "container": "max-w-7xl mx-auto px-4 sm:px-6 lg:px-8",
    "spacing": {
      "section_gap": "py-24 md:py-32",
      "element_gap": "gap-8"
    },
    "grid_system": "Bento Grid (Mode A) for Services, Standard Grid for Features"
  },
  "ui_components": {
    "buttons": {
      "primary": "bg-primary text-white hover:bg-primary/90 shadow-[0_0_20px_rgba(59,130,246,0.5)] rounded-full px-8 py-3 font-semibold transition-all hover:scale-105",
      "secondary": "bg-transparent border border-white/20 text-white hover:bg-white/10 rounded-full px-8 py-3 font-semibold backdrop-blur-sm"
    },
    "cards": {
      "base": "bg-white/5 border border-white/10 rounded-2xl backdrop-blur-md hover:border-white/20 transition-all duration-300 group overflow-hidden",
      "hover_effect": "hover:shadow-[0_0_30px_rgba(59,130,246,0.15)] hover:-translate-y-1"
    },
    "navbar": {
      "style": "fixed top-4 left-1/2 -translate-x-1/2 w-[90%] max-w-5xl bg-black/50 border border-white/10 rounded-full backdrop-blur-xl z-50 px-6 py-4 flex items-center justify-between shadow-2xl"
    }
  },
  "sections": {
    "hero": {
      "style": "min-h-screen flex flex-col items-center justify-center text-center relative overflow-hidden",
      "elements": [
        "Massive Gradient Orb (Background)",
        "3D Floating Code Snippet (Right/Center)",
        "Animated Text Reveal"
      ]
    },
    "stats": {
      "style": "py-12 border-y border-white/5 bg-black/20 backdrop-blur-sm"
    },
    "services": {
      "layout": "Bento Grid (3 columns)",
      "cards": [
        { "title": "Custom Web Apps", "span": "col-span-1 md:col-span-2" },
        { "title": "Business Websites", "span": "col-span-1" },
        { "title": "E-commerce", "span": "col-span-1" },
        { "title": "API Development", "span": "col-span-1 md:col-span-2" }
